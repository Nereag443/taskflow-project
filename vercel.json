{
  "version": 2,
  "builds": [
    {
      "src": "maqueta-tailwind/public/**",
      "use": "@vercel/static"
    },
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server/src/index.js"
    }
  ]
}