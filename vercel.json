{
  "version": 2,
  "builds": [
    {
      "src": "maqueta-tailwind/public/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/src/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/maqueta-tailwind/public/$1"
    }
  ]
}